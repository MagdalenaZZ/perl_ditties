setwd("~/Desktop/Team Science Project/All R2 values/0.1/Network-based druggability score extraction")
#List of genes put into CPAT
gene_list<-read.csv("Genes_in_canSAR.csv")
#Spreadsheet of NBD values from Costas' paper
nbd<-read.csv("NBD_from_paper.csv")
total <- merge(gene_list,nbd,by="PAC")
write.csv(total, "Network-based_druggability_assesment_of_hits.csv")
